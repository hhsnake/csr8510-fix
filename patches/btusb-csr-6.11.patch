+/* Unbranded CSR clones return undersized payloads for several HCI commands.
+ * HCI_QUIRK_BROKEN_READ_VOICE_SETTING and HCI_QUIRK_BROKEN_READ_PAGE_SCAN_TYPE
+ * are not available in this kernel, so we intercept all three commands at the
+ * transport layer and pad the missing byte so the core parser stays in sync.
+ *
+ * Known short responses (clone payload vs. expected):
+ *   HCI_OP_READ_VOICE_SETTING  (0x0c25): 2 bytes instead of 3
+ *   HCI_OP_READ_TX_POWER       (0x0c2d): 3 bytes instead of 4
+ *   HCI_OP_READ_PAGE_SCAN_TYPE (0x0c46): 1 byte  instead of 2
+ */
+static int btusb_recv_event_csr(struct hci_dev *hdev, struct sk_buff *skb)
+{
+	struct hci_event_hdr *hdr = (void *)skb->data;
+	struct hci_ev_cmd_complete *cc;
+	u16 opcode;
+	u8 expected_plen;
+
+	if (skb->len < sizeof(*hdr) + sizeof(*cc) ||
+	    hdr->evt != HCI_EV_CMD_COMPLETE)
+		goto done;
+
+	cc = (void *)(skb->data + sizeof(*hdr));
+	opcode = le16_to_cpu(cc->opcode);
+
+	switch (opcode) {
+	case HCI_OP_READ_VOICE_SETTING:
+		expected_plen = sizeof(*cc) + 3; /* status + __le16 */
+		break;
+	case HCI_OP_READ_TX_POWER:
+		expected_plen = sizeof(*cc) + 4; /* status + __le16 handle + s8 */
+		break;
+	case HCI_OP_READ_PAGE_SCAN_TYPE:
+		expected_plen = sizeof(*cc) + 2; /* status + u8 type */
+		break;
+	default:
+		goto done;
+	}
+
+	if (hdr->plen == expected_plen - 1 && skb_tailroom(skb) >= 1) {
+		bt_dev_dbg(hdev, "CSR: padding short response for opcode 0x%04x", opcode);
+		skb_put_u8(skb, 0x00);
+		hdr->plen++;
+	}
+
+done:
+	return hci_recv_frame(hdev, skb);
+}
