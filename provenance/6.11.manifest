# Provenance manifest — src/6.11 is a GENERATED artifact, do not edit by hand.
#
#   src/6.11/  =  pristine kernel files @ <commit>  +  patches/csr8510-fix-6.11.patch
#
# The trust anchor is the sha256 of each file's content, NOT the download URL.
# Any mirror serving the same bytes is acceptable; tools/regen.sh verifies the
# hash before use and tools/verify.sh proves src/6.11 equals the result. This
# is what lets a reviewer confirm nothing was slipped into the vendored source.

variant  6.11
tag      v6.11
commit   98f7e32f20d28ec452afb208f9cffc08448a2652
patch    patches/csr8510-fix-6.11.patch

# Download mirrors (raw bytes), tried in order. {commit} and {path} substituted.
# Release tags never move and are mirrored widely; if all mirrors are gone, a
# local clone still works:  KERNEL_GIT=/path/to/linux.git tools/regen.sh 6.11
mirror   https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git/plain/{path}?id={commit}
mirror   https://raw.githubusercontent.com/torvalds/linux/{commit}/{path}

