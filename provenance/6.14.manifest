# Provenance manifest — src/6.14 is a GENERATED artifact, do not edit by hand.
#
#   src/6.14/  =  pristine kernel files @ <commit>  +  patches/csr8510-fix-6.14.patch
#
# NOTE: this variant is pinned to the *Ubuntu* kernel tree, not kernel.org.
# Ubuntu 24.04 HWE 6.14 backported the v6.16 quirk_flags API (hci_set_quirk)
# into 6.14, diverging from mainline v6.14 across the whole file, and by kernel
# version alone an Ubuntu-HWE 6.14 is indistinguishable from a vanilla 6.14.
# The realistic consumer of this variant is Ubuntu 24.04 HWE, so we pin to the
# exact Ubuntu source it ships. Trust anchor is the sha256 below; verify the
# bytes independently with: apt-get source linux-image-6.14.0-37-generic
# (source package linux-hwe-6.14, version 6.14.0-37.37~24.04.1).

variant  6.14
tag      Ubuntu-hwe-6.14-6.14.0-37.37_24.04.1
commit   094018d5b62a69f9960feb07e4b925eb2834eeee
patch    patches/csr8510-fix-6.14.patch

# Download mirror (raw bytes). {commit} and {path} substituted. Trust is the
# sha256, not the host; if Launchpad is unreachable, apt-get source (above)
# yields the same bytes, or KERNEL_GIT=<ubuntu clone> tools/regen.sh 6.14.
mirror   https://git.launchpad.net/~ubuntu-kernel/ubuntu/+source/linux/+git/noble/plain/{path}?id={commit}

